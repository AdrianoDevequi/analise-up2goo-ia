# ─── Local ──────────────────────────────────────────────────
# Variáveis usadas no desenvolvimento local (sem DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=analise_ia
DB_USER=analise_user
DB_PASSWORD=analise_pass123

# ─── Railway (produção) ──────────────────────────────────────
# O Railway injeta DATABASE_URL automaticamente quando você adiciona
# o plugin PostgreSQL. Não precisa configurar DB_HOST/DB_PORT/etc.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Flask ──────────────────────────────────────────────────
SECRET_KEY=troque-esta-chave-secreta-por-algo-seguro-em-producao
FLASK_DEBUG=false
# PORT é injetada automaticamente pelo Railway — não configure aqui

# Anthropic (Claude AI) - coloque sua chave aqui
ANTHROPIC_API_KEY=sk-ant-...

# Screaming Frog CLI - caminho do executável (para uso local)
# No servidor, deixe em branco — use o upload de CSV
SF_CLI_PATH=C:\Program Files (x86)\Screaming Frog SEO Spider\ScreamingFrogSEOSpider.exe

# Admin padrão criado na primeira execução
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador
